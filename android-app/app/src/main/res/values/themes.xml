<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base App Theme — Modern vibrant orange -->
    <style name="Theme.QRAttendance" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/orange_600</item>
        <item name="colorPrimaryDark">@color/orange_700</item>
        <item name="colorAccent">@color/orange_500</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Splash Theme — bold orange gradient -->
    <style name="Theme.QRAttendance.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/orange_700</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/orange_700</item>
        <item name="android:windowBackground">@color/orange_700</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Login Theme — warm stone background with vibrant cards -->
    <style name="Theme.QRAttendance.Login" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/orange_600</item>
        <item name="colorAccent">@color/orange_500</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <!-- Rounded input style -->
    <style name="Widget.QR.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/input_border</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxBackgroundColor">@color/input_bg</item>
        <item name="hintTextColor">@color/orange_600</item>
    </style>
</resources>
