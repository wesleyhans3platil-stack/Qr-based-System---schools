<?xml version="1.0" encoding="utf-8"?>
<!-- ═══════════════════════════════════════════════════════════
     BOLD MODERN LOGIN SCREEN
     Warm gradient header + white card + clean form
     ═══════════════════════════════════════════════════════════ -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══ Curved Gradient Header ═══ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="220dp"
            android:background="@drawable/bg_splash_gradient"
            android:paddingTop="40dp"
            android:paddingBottom="48dp">

            <!-- Decorative circle -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-20dp"
                android:layout_marginEnd="-20dp"
                android:background="@drawable/bg_logo_container"
                android:alpha="0.12" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_gravity="center">

                <!-- Logo -->
                <ImageView
                    android:id="@+id/loginLogo"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:src="@drawable/ic_login_logo"
                    android:contentDescription="App Logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EduTrack"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02"
                    android:layout_marginTop="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attendance Monitoring System"
                    android:textSize="12sp"
                    android:textColor="#BBFFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </FrameLayout>

        <!-- ═══ Form Card (overlapping header) ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_frosted"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="26dp"
            android:paddingBottom="22dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="-32dp"
            android:elevation="8dp">

            <!-- Welcome text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:textSize="21sp"
                android:textStyle="bold"
                android:textColor="@color/label_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to continue"
                android:textSize="13sp"
                android:textColor="@color/label_tertiary"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="24dp" />

            <!-- Error message (hidden by default) -->
            <LinearLayout
                android:id="@+id/errorContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_error"
                android:padding="14dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠"
                    android:textSize="16sp"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/errorText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#DC2626"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- Username label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textSize="13sp"
                android:textColor="@color/label_secondary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <!-- Username input -->
            <EditText
                android:id="@+id/usernameInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:hint="Enter your username"
                android:textColorHint="@color/label_quaternary"
                android:textColor="@color/label_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:inputType="text"
                android:imeOptions="actionNext"
                android:maxLines="1"
                android:layout_marginBottom="14dp" />

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="13sp"
                android:textColor="@color/label_secondary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <!-- Password input -->
            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:hint="Enter your password"
                android:textColorHint="@color/label_quaternary"
                android:textColor="@color/label_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:inputType="textPassword"
                android:imeOptions="actionDone"
                android:maxLines="1"
                android:layout_marginBottom="24dp" />

            <!-- Sign In button -->
            <Button
                android:id="@+id/signInBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_btn_primary"
                android:text="Sign In"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:elevation="4dp" />

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/loginProgress"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/green_600"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ═══ Footer ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Schools Division Office — Sipalay City"
                android:textSize="11sp"
                android:textColor="@color/label_quaternary"
                android:fontFamily="sans-serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textSize="10sp"
                android:textColor="@color/label_quaternary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
