<?xml version="1.0" encoding="utf-8"?>
<!-- ═══════════════════════════════════════════════════════════
     MODERN MAIN ACTIVITY
     WebView with bold offline screen + gradient progress bar
     ═══════════════════════════════════════════════════════════ -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:background="@color/white">

    <!-- Pull-to-Refresh + WebView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Top progress bar removed per request -->

    <!-- ═══ Bold Offline Screen ═══ -->
    <ScrollView
        android:id="@+id/offlineView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/bg_primary"
        android:visibility="gone"
        android:fitsSystemWindows="true">
        <!-- hide visible scrollbars while keeping scrolling functional -->
        

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- Circular accent behind icon -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_logo_container"
                android:alpha="0.1" />

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_offline"
                android:contentDescription="Offline"
                android:alpha="0.6" />

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Connection"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/label_primary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Check your Wi-Fi or mobile data and make sure the server is running."
            android:textSize="14sp"
            android:textColor="@color/label_tertiary"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:maxWidth="300dp"
            android:layout_marginBottom="32dp" />

        <!-- Retry button -->
        <Button
            android:id="@+id/retryButton"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_primary"
            android:text="Try Again"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"
            android:elevation="4dp" />

        <!-- Sign out link -->
        <TextView
            android:id="@+id/logoutOfflineBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign Out"
            android:textSize="14sp"
            android:textColor="@color/green_600"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="20dp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
    </ScrollView>

</FrameLayout>
