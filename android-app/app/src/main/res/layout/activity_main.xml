<?xml version="1.0" encoding="utf-8"?>
<!-- ═══════════════════════════════════════════════════════════
     MODERN MAIN ACTIVITY
     WebView with bold offline screen + gradient progress bar
     ═══════════════════════════════════════════════════════════ -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Pull-to-Refresh + WebView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Orange progress bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:progressTint="@color/orange_500"
        android:progressBackgroundTint="@android:color/transparent"
        android:max="100"
        android:visibility="gone" />

    <!-- ═══ Bold Offline Screen ═══ -->
    <LinearLayout
        android:id="@+id/offlineView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_primary"
        android:visibility="gone"
        android:padding="40dp">

        <!-- Orange circular accent behind icon -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="28dp">

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_logo_container"
                android:alpha="0.1" />

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_offline"
                android:contentDescription="Offline"
                android:alpha="0.6" />

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Connection"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/label_primary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:text="Check your Wi-Fi or mobile data and make sure the server is running."
            android:textSize="14sp"
            android:textColor="@color/label_tertiary"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="36dp" />

        <!-- Retry button -->
        <Button
            android:id="@+id/retryButton"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_primary"
            android:text="Try Again"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"
            android:elevation="4dp" />

        <!-- Sign out link -->
        <TextView
            android:id="@+id/logoutOfflineBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign Out"
            android:textSize="14sp"
            android:textColor="@color/orange_600"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="20dp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
