<?xml version="1.0" encoding="utf-8"?>
<!-- ═══ Bold Splash Screen — Emerald Green Gradient ═══ -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <!-- Decorative top-right circle -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_logo_container"
        android:alpha="0.15" />

    <!-- Decorative bottom-left circle -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-40dp"
        android:layout_marginStart="-40dp"
        android:background="@drawable/bg_logo_container"
        android:alpha="0.1" />

    <!-- Center content -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="center">

        <!-- Circular icon with white border -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp">

            <!-- White ring behind icon -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_logo_container"
                android:alpha="0.25" />

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/splash_icon"
                android:contentDescription="@string/app_name" />

        </FrameLayout>

        <!-- App Name — large and bold -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@android:color/white"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:layout_marginTop="24dp" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Attendance Monitoring System"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:layout_marginTop="8dp" />

        <!-- Divider dot -->
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_logo_container"
            android:alpha="0.5" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SDO — Sipalay City"
            android:textColor="#99FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.08"
            android:layout_marginTop="12dp" />

    </LinearLayout>

    <!-- Bottom loading indicator -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="72dp">

        <ProgressBar
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:indeterminateTint="#CCFFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading"
            android:textColor="#99FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:layout_marginStart="12dp" />

    </LinearLayout>

</FrameLayout>
